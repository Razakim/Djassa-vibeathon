    "var_6a4c954a1b27": {
      "type": "variant",
      "label": "Industrial Brutalism",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1525.5019612027695,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Archivo+Black&family=Roboto+Mono:wght@400;700&display=swap');\n\n  .font-brutal-head { font-family: 'Archivo Black', sans-serif; }\n  .font-brutal-mono { font-family: 'Roboto Mono', monospace; }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    display: inline-flex;\n    animation: marquee 20s linear infinite;\n  }\n</style>\n\n<div class=\"bg-[oklch(1_0_0)] text-[oklch(0.141_0.005_285.823)] font-brutal-mono min-h-screen\" data-kid=\"1\">\n  \n  <section class=\"flex flex-col md:flex-row h-screen border-b-2 border-black\" data-kid=\"2\">\n    <div class=\"md:w-1/2 p-8 md:p-16 flex flex-col justify-center border-r-2 border-black\" data-kid=\"3\">\n      <h1 class=\"text-6xl md:text-8xl font-brutal-head uppercase leading-none mb-8\" data-kid=\"4\">\n        The Operating System for West African Transport\n      </h1>\n      <p class=\"text-xl max-w-md mb-8\" data-kid=\"5\">\n        Centralize fleet, drivers, and missions into one robust infrastructure. No more WhatsApp chaos.\n      </p>\n      <div class=\"flex gap-4\" data-kid=\"6\">\n        <button class=\"bg-black text-white px-8 py-4 text-xl font-brutal-head uppercase hover:bg-zinc-800 transition-colors cursor-pointer\" data-kid=\"7\">\n          Get Started\n        </button>\n      </div>\n    </div>\n    <div class=\"md:w-1/2 relative bg-black overflow-hidden\" data-kid=\"8\">\n      <video src=\"https://videos.pexels.com/video-files/28744906/12461966_640_360_24fps.mp4\" poster=\"https://images.pexels.com/videos/28744906/cargo-cargo-trailers-cargo-transport-commercial-truck-28744906.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover\" data-kid=\"9\"></video>\n    </div>\n  </section>\n\n  \n  <div class=\"border-b-2 border-black py-6 bg-black text-white overflow-hidden whitespace-nowrap\" data-kid=\"10\">\n    <div class=\"animate-marquee\" data-kid=\"11\">\n      <span class=\"text-4xl font-brutal-head uppercase mx-8\" data-kid=\"12\">Fleet • Drivers • Missions • Accounting • Logistics • Efficiency</span>\n      <span class=\"text-4xl font-brutal-head uppercase mx-8\" data-kid=\"13\">Fleet • Drivers • Missions • Accounting • Logistics • Efficiency</span>\n    </div>\n  </div>\n\n  \n  <section class=\"flex flex-col\" data-kid=\"14\">\n    \n    <div class=\"border-b-2 border-black group cursor-default\" data-kid=\"15\">\n      <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center p-8 md:p-20 gap-12\" data-kid=\"16\">\n        <div class=\"text-8xl md:text-[12rem] font-brutal-head text-zinc-200 group-hover:text-black transition-colors duration-300\" data-kid=\"17\">01</div>\n        <div class=\"flex-1\" data-kid=\"18\">\n          <h3 class=\"text-4xl md:text-6xl font-brutal-head uppercase mb-6\" data-kid=\"19\">Fleet Management</h3>\n          <p class=\"text-lg max-w-xl\" data-kid=\"20\">\n            Real-time tracking, fuel monitoring, and predictive maintenance for your entire West African fleet.\n          </p>\n        </div>\n        <div class=\"w-full md:w-1/3 aspect-video relative border-2 border-black overflow-hidden bg-zinc-100\" data-kid=\"21\">\n           <img src=\"https://images.pexels.com/photos/20097991/pexels-photo-20097991.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Modern heavy duty cargo truck side profile by Eddson Lens on Pexels\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500\" data-kid=\"22\">\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"border-b-2 border-black group cursor-default\" data-kid=\"23\">\n      <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row-reverse items-center p-8 md:p-20 gap-12\" data-kid=\"24\">\n        <div class=\"text-8xl md:text-[12rem] font-brutal-head text-zinc-200 group-hover:text-black transition-colors duration-300\" data-kid=\"25\">02</div>\n        <div class=\"flex-1\" data-kid=\"26\">\n          <h3 class=\"text-4xl md:text-6xl font-brutal-head uppercase mb-6\" data-kid=\"27\">Driver Performance</h3>\n          <p class=\"text-lg max-w-xl\" data-kid=\"28\">\n            Monitor punctuality, safety scores, and mission success rates. Digitized HR for your mobile workforce.\n          </p>\n        </div>\n        <div class=\"w-full md:w-1/3 aspect-video border-2 border-black p-4 flex flex-col justify-between bg-black text-white\" data-kid=\"29\">\n          <div class=\"flex justify-between items-start\" data-kid=\"30\">\n            <span class=\"text-xs font-bold uppercase\" data-kid=\"31\">Driver ID: 942</span>\n            <span class=\"px-2 py-1 bg-green-500 text-black text-[10px] font-bold\" data-kid=\"32\">ACTIVE</span>\n          </div>\n          <div class=\"text-2xl font-brutal-head\" data-kid=\"33\">KWAME MENSAH</div>\n          <div class=\"w-full bg-zinc-800 h-2\" data-kid=\"34\">\n            <div class=\"bg-white h-full w-[92%]\" data-kid=\"35\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"border-b-2 border-black group cursor-default\" data-kid=\"36\">\n      <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center p-8 md:p-20 gap-12\" data-kid=\"37\">\n        <div class=\"text-8xl md:text-[12rem] font-brutal-head text-zinc-200 group-hover:text-black transition-colors duration-300\" data-kid=\"38\">03</div>\n        <div class=\"flex-1\" data-kid=\"39\">\n          <h3 class=\"text-4xl md:text-6xl font-brutal-head uppercase mb-6\" data-kid=\"40\">Mission Control</h3>\n          <p class=\"text-lg max-w-xl\" data-kid=\"41\">\n            From creation to proof-of-delivery. Fully digitized workflows that eliminate paperwork and errors.\n          </p>\n        </div>\n        <div class=\"w-full md:w-1/3 border-2 border-black p-6 bg-white\" data-kid=\"42\">\n          <div class=\"flex items-center gap-2 mb-4\" data-kid=\"43\">\n            <i class=\"ti ti-shield-check text-2xl\" data-kid=\"44\"></i>\n            <span class=\"font-bold\" data-kid=\"45\">VERIFIED DELIVERY</span>\n          </div>\n          <div class=\"space-y-2 text-sm border-t border-black pt-4\" data-kid=\"46\">\n            <div class=\"flex justify-between\" data-kid=\"47\"><span data-kid=\"48\">Origin</span><span class=\"font-bold\" data-kid=\"49\">ABIDJAN</span></div>\n            <div class=\"flex justify-between\" data-kid=\"50\"><span data-kid=\"51\">Dest</span><span class=\"font-bold\" data-kid=\"52\">BAMAKO</span></div>\n            <div class=\"flex justify-between\" data-kid=\"53\"><span data-kid=\"54\">Status</span><span class=\"font-bold\" data-kid=\"55\">COMPLETED</span></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 border-b-2 border-black bg-zinc-50\" data-kid=\"56\">\n    <div class=\"max-w-7xl mx-auto px-8\" data-kid=\"57\">\n      <h2 class=\"text-4xl md:text-6xl font-brutal-head uppercase mb-16 text-center\" data-kid=\"58\">Absolute Control • Higher Margins</h2>\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"59\">\n        <div class=\"aspect-square border-2 border-black p-8 flex flex-col justify-between bg-white hover:bg-zinc-100 transition-colors cursor-default\" data-kid=\"60\">\n          <i class=\"ti ti-trending-up text-5xl\" data-kid=\"61\"></i>\n          <div data-kid=\"62\">\n            <div class=\"text-6xl font-brutal-head\" data-kid=\"63\">+32%</div>\n            <div class=\"text-xl font-bold uppercase mt-2\" data-kid=\"64\">Operational Margin</div>\n          </div>\n        </div>\n        <div class=\"aspect-square border-2 border-black p-8 flex flex-col justify-between bg-black text-white hover:bg-zinc-900 transition-colors cursor-default\" data-kid=\"65\">\n          <div class=\"text-5xl font-brutal-head\" data-kid=\"66\">0</div>\n          <div data-kid=\"67\">\n            <div class=\"text-3xl font-brutal-head uppercase\" data-kid=\"68\">Lost Documents</div>\n            <p class=\"mt-2 opacity-70\" data-kid=\"69\">Total visibility from the first mile.</p>\n          </div>\n        </div>\n        <div class=\"aspect-square border-2 border-black p-8 flex flex-col justify-between bg-white hover:bg-zinc-100 transition-colors cursor-default\" data-kid=\"70\">\n          <div class=\"text-6xl font-brutal-head\" data-kid=\"71\">100%</div>\n          <div data-kid=\"72\">\n            <div class=\"text-xl font-bold uppercase mt-2\" data-kid=\"73\">Compliance Rate</div>\n            <p class=\"mt-2\" data-kid=\"74\">Real-time alerts for expiring documents.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"min-h-[80vh] bg-black text-white flex flex-col items-center justify-center p-8 text-center\" data-kid=\"75\">\n    <h2 class=\"text-6xl md:text-[10rem] font-brutal-head uppercase leading-none mb-12\" data-kid=\"76\">TRANSFORM NOW</h2>\n    <div class=\"w-full max-w-4xl border-2 border-white flex flex-col md:flex-row p-2\" data-kid=\"77\">\n      <input type=\"email\" placeholder=\"ENTER YOUR CORPORATE EMAIL\" class=\"flex-1 bg-transparent text-white px-6 py-4 text-2xl font-brutal-mono focus:outline-none placeholder:opacity-30 uppercase\" data-kid=\"78\">\n      <button class=\"bg-white text-black px-12 py-4 text-2xl font-brutal-head uppercase hover:bg-zinc-200 transition-colors cursor-pointer\" data-kid=\"79\">\n        SUBMIT\n      </button>\n    </div>\n    <div class=\"mt-12 opacity-50 font-brutal-mono uppercase tracking-widest\" data-kid=\"80\">\n      Infrastructure for West African Logistics\n    </div>\n  </section>\n  \n  <footer class=\"p-8 border-t-2 border-black flex flex-col md:flex-row justify-between items-center gap-4 bg-white\" data-kid=\"81\">\n    <div class=\"text-2xl font-brutal-head\" data-kid=\"82\">GTRAN</div>\n    <div class=\"flex gap-8 uppercase font-bold text-sm\" data-kid=\"83\">\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"84\">Fleet</a>\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"85\">Drivers</a>\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"86\">Missions</a>\n      <a href=\"#\" class=\"hover:underline\" data-kid=\"87\">Ecosystem</a>\n    </div>\n    <div class=\"text-sm opacity-50 uppercase\" data-kid=\"88\">© 2024 GTRAN OPERATING SYSTEM</div>\n  </footer>\n</div>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"89\">",
