      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --radius: 0.625rem;\n    --background: oklch(0.141 0.005 285.823);\n    --foreground: oklch(0.985 0 0);\n    --primary: oklch(0.92 0.004 286.32);\n    --primary-foreground: oklch(0.21 0.006 285.885);\n    --border: oklch(1 0 0 / 10%);\n    --card: oklch(0.21 0.006 285.885);\n    --accent: oklch(0.274 0.006 286.033);\n    --chart-1: oklch(0.488 0.243 264.376);\n  }\n\n  body {\n    background-color: var(--background);\n    color: var(--foreground);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n\n  .command-grid {\n    background-image: radial-gradient(var(--border) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .scanline {\n    width: 100%;\n    height: 100px;\n    z-index: 10;\n    background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(255, 255, 255, 0.05) 50%, rgba(0, 0, 0, 0) 100%);\n    opacity: 0.1;\n    position: fixed;\n    bottom: 100%;\n    left: 0;\n    pointer-events: none;\n    animation: scanline 10s linear infinite;\n  }\n\n  @keyframes scanline {\n    0% { bottom: 100%; }\n    100% { bottom: -100px; }\n  }\n\n  .bento-card {\n    border: 1px solid var(--border);\n    background: rgba(33, 33, 33, 0.5);\n    backdrop-filter: blur(10px);\n    transition: all 0.3s ease;\n  }\n\n  .bento-card:hover {\n    border-color: var(--primary);\n    box-shadow: 0 0 20px rgba(255, 255, 255, 0.05);\n  }\n</style>\n\n<div class=\"command-grid min-h-screen selection:bg-white selection:text-black\" data-kid=\"1\">\n  <div class=\"scanline\" data-kid=\"2\"></div>\n\n  \n  <nav class=\"border-b border-(--border) px-8 py-6 flex items-center justify-between sticky top-0 z-50 bg-(--background)/80 backdrop-blur-md\" data-kid=\"3\">\n    <div class=\"flex items-center gap-2\" data-kid=\"4\">\n      <div class=\"w-8 h-8 bg-(--primary) flex items-center justify-center\" data-kid=\"5\">\n        <i class=\"ti ti-activity text-(--primary-foreground) text-xl\" data-kid=\"6\"></i>\n      </div>\n      <span class=\"font-space text-2xl font-bold tracking-tight\" data-kid=\"7\">GTRAN</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8 font-space text-sm uppercase tracking-widest text-(--foreground)/60\" data-kid=\"8\">\n      <a href=\"#\" class=\"hover:text-(--primary) transition-colors\" data-kid=\"9\">Fleet</a>\n      <a href=\"#\" class=\"hover:text-(--primary) transition-colors\" data-kid=\"10\">Drivers</a>\n      <a href=\"#\" class=\"hover:text-(--primary) transition-colors\" data-kid=\"11\">Missions</a>\n      <a href=\"#\" class=\"hover:text-(--primary) transition-colors\" data-kid=\"12\">Ecosystem</a>\n    </div>\n    <button class=\"font-space text-xs uppercase tracking-[0.2em] border border-(--primary) px-6 py-3 hover:bg-(--primary) hover:text-(--primary-foreground) transition-all\" data-kid=\"13\">\n      Deploy System\n    </button>\n  </nav>\n\n  \n  <section class=\"relative pt-24 pb-32 px-8 overflow-hidden\" data-kid=\"14\">\n    <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\" data-kid=\"15\">\n      <div class=\"z-10\" data-kid=\"16\">\n        <div class=\"inline-flex items-center gap-2 border border-(--border) px-3 py-1 mb-8\" data-kid=\"17\">\n          <span class=\"w-2 h-2 bg-green-500 animate-pulse\" data-kid=\"18\"></span>\n          <span class=\"font-space text-[10px] uppercase tracking-[0.3em] opacity-60\" data-kid=\"19\">System Active: West Africa v1.0</span>\n        </div>\n        <h1 class=\"font-space text-7xl lg:text-8xl font-bold leading-[0.9] mb-8 tracking-tighter hero-title\" data-kid=\"20\">\n          Stop guessing.<br data-kid=\"21\">\n          <span class=\"text-(--primary)\" data-kid=\"22\">Start orchestrating.</span>\n        </h1>\n        <p class=\"text-xl text-(--foreground)/60 max-w-lg mb-12 leading-relaxed hero-sub\" data-kid=\"23\">\n          The high-precision operating system for West African logistics. Replace WhatsApp chaos and Excel fragmentation with a definitive digital command center.\n        </p>\n        <div class=\"flex flex-wrap gap-4 hero-btns\" data-kid=\"24\">\n          <button class=\"bg-(--primary) text-(--primary-foreground) font-space uppercase tracking-widest text-sm px-10 py-5 font-bold hover:brightness-110 transition-all\" data-kid=\"25\">\n            Start Mission\n          </button>\n          <button class=\"border border-(--border) font-space uppercase tracking-widest text-sm px-10 py-5 font-bold hover:bg-white/5 transition-all\" data-kid=\"26\">\n            Watch Feed\n          </button>\n        </div>\n      </div>\n\n      <div class=\"relative hero-visual\" data-kid=\"27\">\n        <div class=\"absolute inset-0 bg-(--primary)/5 blur-[120px] rounded-full\" data-kid=\"28\"></div>\n        <div class=\"relative border border-(--border) bg-(--card)/40 backdrop-blur-xl p-2\" data-kid=\"29\">\n          <div class=\"absolute -top-4 -right-4 bg-(--primary) text-(--primary-foreground) px-3 py-1 font-space text-[10px] font-bold z-20\" data-kid=\"30\">LIVE MAP</div>\n          <img src=\"https://images.unsplash.com/photo-1774013607215-9f21488e9a19?auto=format&w=800&q=80\" alt=\"Zoshua Colah on Unsplash\" class=\"w-full grayscale opacity-80\" decoding=\"async\" loading=\"lazy\" data-kid=\"31\">\n          <div class=\"absolute bottom-8 left-8 right-8 grid grid-cols-2 gap-4\" data-kid=\"32\">\n            <div class=\"border border-(--border) bg-(--background)/80 p-4 backdrop-blur-sm\" data-kid=\"33\">\n              <div class=\"font-space text-[10px] opacity-40 uppercase mb-1\" data-kid=\"34\">Active Fleet</div>\n              <div class=\"text-2xl font-space font-bold tracking-tighter\" data-kid=\"35\">1,248</div>\n            </div>\n            <div class=\"border border-(--border) bg-(--background)/80 p-4 backdrop-blur-sm\" data-kid=\"36\">\n              <div class=\"font-space text-[10px] opacity-40 uppercase mb-1\" data-kid=\"37\">In Transit</div>\n              <div class=\"text-2xl font-space font-bold tracking-tighter text-green-500\" data-kid=\"38\">98.4%</div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"absolute -bottom-10 -left-10 w-40 h-40 border-l border-b border-(--primary)/30\" data-kid=\"39\"></div>\n        <div class=\"absolute top-1/2 -right-8 flex flex-col gap-2\" data-kid=\"40\">\n          <div class=\"w-2 h-2 bg-(--primary)\" data-kid=\"41\"></div>\n          <div class=\"w-2 h-2 bg-(--primary)/40\" data-kid=\"42\"></div>\n          <div class=\"w-2 h-2 bg-(--primary)/20\" data-kid=\"43\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-8 border-t border-(--border) bg-black/20\" data-kid=\"44\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"45\">\n      <div class=\"text-center mb-24\" data-kid=\"46\">\n        <h2 class=\"font-space text-4xl font-bold uppercase tracking-widest mb-4\" data-kid=\"47\">Eliminate Fragmented Operations</h2>\n        <div class=\"w-20 h-1 bg-(--primary) mx-auto\" data-kid=\"48\"></div>\n      </div>\n\n      <div class=\"grid lg:grid-cols-2 border border-(--border)\" data-kid=\"49\">\n        \n        <div class=\"p-16 border-b lg:border-b-0 lg:border-r border-(--border) relative group overflow-hidden\" data-kid=\"50\">\n          <div class=\"absolute top-0 left-0 w-full h-1 bg-red-500/30\" data-kid=\"51\"></div>\n          <div class=\"flex items-center gap-3 mb-8\" data-kid=\"52\">\n            <i class=\"ti ti-alert-triangle text-red-500 text-2xl\" data-kid=\"53\"></i>\n            <h3 class=\"font-space text-xl font-bold uppercase text-red-500/80\" data-kid=\"54\">Legacy Chaos</h3>\n          </div>\n          <ul class=\"space-y-6 text-(--foreground)/40\" data-kid=\"55\">\n            <li class=\"flex items-start gap-4\" data-kid=\"56\">\n              <span class=\"font-space text-xs border border-red-500/30 px-2 py-0.5 text-red-500/50\" data-kid=\"57\">FRAG</span>\n              <p data-kid=\"58\">Missions managed across 12+ fragmented WhatsApp groups.</p>\n            </li>\n            <li class=\"flex items-start gap-4\" data-kid=\"59\">\n              <span class=\"font-space text-xs border border-red-500/30 px-2 py-0.5 text-red-500/50\" data-kid=\"60\">LOSS</span>\n              <p data-kid=\"61\">Physical proof of delivery lost in transcontinental transits.</p>\n            </li>\n            <li class=\"flex items-start gap-4\" data-kid=\"62\">\n              <span class=\"font-space text-xs border border-red-500/30 px-2 py-0.5 text-red-500/50\" data-kid=\"63\">VOID</span>\n              <p data-kid=\"64\">Zero visibility on real-time driver location or fuel consumption.</p>\n            </li>\n          </ul>\n          <div class=\"mt-16 opacity-10 group-hover:opacity-20 transition-opacity\" data-kid=\"65\">\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"66\">\n              <div class=\"p-2 border border-dashed border-red-500 w-32 h-20\" data-kid=\"67\"></div>\n              <div class=\"p-2 border border-dashed border-red-500 w-48 h-20\" data-kid=\"68\"></div>\n              <div class=\"p-2 border border-dashed border-red-500 w-20 h-20\" data-kid=\"69\"></div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"p-16 relative bg-(--primary)/5 overflow-hidden\" data-kid=\"70\">\n          <div class=\"absolute top-0 left-0 w-full h-1 bg-(--primary)\" data-kid=\"71\"></div>\n          <div class=\"flex items-center gap-3 mb-8\" data-kid=\"72\">\n            <i class=\"ti ti-circle-check text-(--primary) text-2xl\" data-kid=\"73\"></i>\n            <h3 class=\"font-space text-xl font-bold uppercase text-(--primary)\" data-kid=\"74\">Gtran Order</h3>\n          </div>\n          <ul class=\"space-y-6\" data-kid=\"75\">\n            <li class=\"flex items-start gap-4\" data-kid=\"76\">\n              <span class=\"font-space text-xs bg-(--primary) text-(--primary-foreground) px-2 py-0.5\" data-kid=\"77\">SYNC</span>\n              <p data-kid=\"78\">One definitive truth. Real-time status for every vehicle and driver.</p>\n            </li>\n            <li class=\"flex items-start gap-4\" data-kid=\"79\">\n              <span class=\"font-space text-xs bg-(--primary) text-(--primary-foreground) px-2 py-0.5\" data-kid=\"80\">VAULT</span>\n              <p data-kid=\"81\">Cloud-centralized documents. Assurances, permits, and LDVs accessible 24/7.</p>\n            </li>\n            <li class=\"flex items-start gap-4\" data-kid=\"82\">\n              <span class=\"font-space text-xs bg-(--primary) text-(--primary-foreground) px-2 py-0.5\" data-kid=\"83\">EDGE</span>\n              <p data-kid=\"84\">Automated ROI analysis. Know your most profitable routes in real-time.</p>\n            </li>\n          </ul>\n          <div class=\"mt-16 bg-(--background) border border-(--border) p-4 shadow-2xl relative\" data-kid=\"85\">\n            <div class=\"flex items-center justify-between mb-4 border-b border-(--border) pb-2\" data-kid=\"86\">\n              <span class=\"font-space text-[10px] uppercase\" data-kid=\"87\">Active Mission: M-2940</span>\n              <span class=\"text-green-500 text-[10px] font-bold\" data-kid=\"88\">ON TRACK</span>\n            </div>\n            <div class=\"flex items-center gap-4\" data-kid=\"89\">\n              <div class=\"w-12 h-12 bg-(--primary)/10 flex items-center justify-center\" data-kid=\"90\">\n                <i class=\"ti ti-truck text-(--primary)\" data-kid=\"91\"></i>\n              </div>\n              <div class=\"flex-1\" data-kid=\"92\">\n                <div class=\"h-1 bg-(--border) rounded-full overflow-hidden\" data-kid=\"93\">\n                  <div class=\"h-full bg-(--primary) w-3/4\" data-kid=\"94\"></div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-8\" data-kid=\"95\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"96\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8\" data-kid=\"97\">\n        <div data-kid=\"98\">\n          <h2 class=\"font-space text-5xl font-bold tracking-tighter mb-4 uppercase\" data-kid=\"99\">Modular Core</h2>\n          <p class=\"text-(--foreground)/60 max-w-md\" data-kid=\"100\">Comprehensive infrastructure for every logistics domain.</p>\n        </div>\n        <div class=\"font-space text-[10px] uppercase tracking-[0.4em] opacity-40\" data-kid=\"101\">Section 03 // Infrastructure</div>\n      </div>\n\n      <div class=\"grid md:grid-cols-12 gap-4\" data-kid=\"102\">\n        <div class=\"md:col-span-8 bento-card p-10 flex flex-col justify-between min-h-[400px]\" data-kid=\"103\">\n          <div data-kid=\"104\">\n            <i class=\"ti ti-truck text-4xl text-(--primary) mb-6\" data-kid=\"105\"></i>\n            <h3 class=\"font-space text-3xl font-bold mb-4 uppercase\" data-kid=\"106\">Fleet Command</h3>\n            <p class=\"text-(--foreground)/60 max-w-sm\" data-kid=\"107\">Manage trucks, trailers, and utility vehicles. Track maintenance, insurance expirations, and real-time availability in a technical grid.</p>\n          </div>\n          <div class=\"mt-12 flex gap-2\" data-kid=\"108\">\n            <div class=\"flex-1 h-20 bg-(--primary)/5 border border-(--border)\" data-kid=\"109\"></div>\n            <div class=\"flex-1 h-20 bg-(--primary)/5 border border-(--border)\" data-kid=\"110\"></div>\n            <div class=\"flex-1 h-20 bg-(--primary)/5 border border-(--border)\" data-kid=\"111\"></div>\n          </div>\n        </div>\n        \n        <div class=\"md:col-span-4 bento-card p-10 flex flex-col justify-between min-h-[400px] bg-(--primary) text-(--primary-foreground)\" data-kid=\"112\">\n          <div data-kid=\"113\">\n            <i class=\"ti ti-users text-4xl mb-6\" data-kid=\"114\"></i>\n            <h3 class=\"font-space text-3xl font-bold mb-4 uppercase\" data-kid=\"115\">Driver CRM</h3>\n            <p class=\"opacity-80\" data-kid=\"116\">Full history, licenses, performance analytics, and automated payouts. The central hub for your human capital.</p>\n          </div>\n          <div class=\"text-4xl font-space font-bold tracking-tighter\" data-kid=\"117\">\n            99.2% <span class=\"text-xs uppercase tracking-widest block opacity-60\" data-kid=\"118\">Retention Rate</span>\n          </div>\n        </div>\n\n        <div class=\"md:col-span-4 bento-card p-10 min-h-[300px]\" data-kid=\"119\">\n          <i class=\"ti ti-map-pin text-4xl text-(--primary) mb-6\" data-kid=\"120\"></i>\n          <h3 class=\"font-space text-2xl font-bold mb-4 uppercase\" data-kid=\"121\">Mission Control</h3>\n          <p class=\"text-(--foreground)/60 text-sm\" data-kid=\"122\">Step-by-step mission tracking from departure to delivery confirmation.</p>\n        </div>\n\n        <div class=\"md:col-span-4 bento-card p-10 min-h-[300px]\" data-kid=\"123\">\n          <i class=\"ti ti-file-text text-4xl text-(--primary) mb-6\" data-kid=\"124\"></i>\n          <h3 class=\"font-space text-2xl font-bold mb-4 uppercase\" data-kid=\"125\">Smart Docs</h3>\n          <p class=\"text-(--foreground)/60 text-sm\" data-kid=\"126\">Automated OCR for BOLs and proof-of-delivery documents.</p>\n        </div>\n\n        <div class=\"md:col-span-4 bento-card p-10 min-h-[300px]\" data-kid=\"127\">\n          <i class=\"ti ti-chart-bar text-4xl text-(--primary) mb-6\" data-kid=\"128\"></i>\n          <h3 class=\"font-space text-2xl font-bold mb-4 uppercase\" data-kid=\"129\">Analytics</h3>\n          <p class=\"text-(--foreground)/60 text-sm\" data-kid=\"130\">Real-time margin calculation and fuel efficiency monitoring.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-8 bg-white/5 border-y border-(--border) relative overflow-hidden\" data-kid=\"131\">\n    \n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/square.svg\" class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] opacity-[0.02] pointer-events-none\" alt=\"pattern\" data-kid=\"132\">\n\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"133\">\n      <div class=\"text-center mb-24\" data-kid=\"134\">\n        <h2 class=\"font-space text-5xl font-bold uppercase tracking-tighter mb-4\" data-kid=\"135\">The Digital Infrastructure</h2>\n        <p class=\"text-(--foreground)/60\" data-kid=\"136\">From ERP to an integrated West African trade ecosystem.</p>\n      </div>\n\n      <div class=\"relative max-w-4xl mx-auto\" data-kid=\"137\">\n        <div class=\"absolute left-1/2 top-0 bottom-0 w-px bg-(--border) -translate-x-1/2 hidden md:block\" data-kid=\"138\"></div>\n        \n        <div class=\"space-y-24 relative z-10\" data-kid=\"139\">\n          \n          <div class=\"flex flex-col md:flex-row items-center gap-8 md:gap-0\" data-kid=\"140\">\n            <div class=\"flex-1 md:text-right md:pr-12 order-2 md:order-1\" data-kid=\"141\">\n              <h4 class=\"font-space text-2xl font-bold mb-2 text-(--primary)\" data-kid=\"142\">01. Core OS</h4>\n              <p class=\"text-(--foreground)/60\" data-kid=\"143\">Centralize your internal operations. Fleet, drivers, and missions under one high-precision interface.</p>\n            </div>\n            <div class=\"w-4 h-4 bg-(--primary) border-4 border-(--background) z-20 order-1 md:order-2\" data-kid=\"144\"></div>\n            <div class=\"flex-1 md:pl-12 order-3\" data-kid=\"145\"></div>\n          </div>\n\n          \n          <div class=\"flex flex-col md:flex-row items-center gap-8 md:gap-0\" data-kid=\"146\">\n            <div class=\"flex-1 order-3 md:order-1\" data-kid=\"147\"></div>\n            <div class=\"w-4 h-4 bg-(--primary) border-4 border-(--background) z-20 order-1 md:order-2\" data-kid=\"148\"></div>\n            <div class=\"flex-1 md:pl-12 order-2 md:order-3\" data-kid=\"149\">\n              <h4 class=\"font-space text-2xl font-bold mb-2 text-(--primary)\" data-kid=\"150\">02. Marketplace</h4>\n              <p class=\"text-(--foreground)/60\" data-kid=\"151\">Smart load matching. Connect with verified shippers and optimize your empty return legs.</p>\n            </div>\n          </div>\n\n          \n          <div class=\"flex flex-col md:flex-row items-center gap-8 md:gap-0\" data-kid=\"152\">\n            <div class=\"flex-1 md:text-right md:pr-12 order-2 md:order-1\" data-kid=\"153\">\n              <h4 class=\"font-space text-2xl font-bold mb-2 text-(--primary)\" data-kid=\"154\">03. Fintech Layer</h4>\n              <p class=\"text-(--foreground)/60\" data-kid=\"155\">Invoice factoring, fuel credits, and automated cargo insurance. Powering the movement of capital.</p>\n            </div>\n            <div class=\"w-4 h-4 bg-(--primary) border-4 border-(--background) z-20 order-1 md:order-2\" data-kid=\"156\"></div>\n            <div class=\"flex-1 md:pl-12 order-3\" data-kid=\"157\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 px-8 text-center relative overflow-hidden\" data-kid=\"158\">\n    <div class=\"max-w-3xl mx-auto relative z-10\" data-kid=\"159\">\n      <h2 class=\"font-space text-6xl md:text-7xl font-bold uppercase tracking-tighter mb-8 leading-[0.9]\" data-kid=\"160\">Ready to deploy?</h2>\n      <p class=\"text-xl text-(--foreground)/60 mb-12\" data-kid=\"161\">Join the digital infrastructure of West African logistics today.</p>\n      <div class=\"flex flex-col sm:flex-row justify-center gap-4\" data-kid=\"162\">\n        <button class=\"bg-white text-black font-space uppercase tracking-widest text-sm px-12 py-6 font-bold hover:bg-(--primary) hover:text-(--primary-foreground) transition-all\" data-kid=\"163\">\n          Request Access\n        </button>\n        <button class=\"border border-(--border) font-space uppercase tracking-widest text-sm px-12 py-6 font-bold hover:bg-white/5 transition-all\" data-kid=\"164\">\n          Contact Intel\n        </button>\n      </div>\n    </div>\n    \n    <div class=\"absolute bottom-0 left-0 p-8\" data-kid=\"165\">\n      <div class=\"font-space text-[10px] opacity-20 text-left\" data-kid=\"166\">\n        LAT: 6.5244° N<br data-kid=\"167\">\n        LON: 3.3792° E\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"border-t border-(--border) py-20 px-8\" data-kid=\"168\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12\" data-kid=\"169\">\n      <div class=\"max-w-xs\" data-kid=\"170\">\n        <div class=\"flex items-center gap-2 mb-6\" data-kid=\"171\">\n          <div class=\"w-6 h-6 bg-(--primary)\" data-kid=\"172\"></div>\n          <span class=\"font-space text-xl font-bold tracking-tight\" data-kid=\"173\">GTRAN</span>\n        </div>\n        <p class=\"text-sm text-(--foreground)/40 leading-relaxed\" data-kid=\"174\">\n          The Operating System for West African transport and logistics. High-precision infrastructure for modern trade.\n        </p>\n      </div>\n      \n      <div class=\"grid grid-cols-2 sm:grid-cols-3 gap-16\" data-kid=\"175\">\n        <div data-kid=\"176\">\n          <h5 class=\"font-space text-[10px] uppercase tracking-widest opacity-40 mb-6\" data-kid=\"177\">Product</h5>\n          <ul class=\"text-sm space-y-4 text-(--foreground)/60 font-space uppercase tracking-tighter\" data-kid=\"178\">\n            <li data-kid=\"179\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"180\">Command</a></li>\n            <li data-kid=\"181\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"182\">Fleet</a></li>\n            <li data-kid=\"183\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"184\">Drivers</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"185\">\n          <h5 class=\"font-space text-[10px] uppercase tracking-widest opacity-40 mb-6\" data-kid=\"186\">System</h5>\n          <ul class=\"text-sm space-y-4 text-(--foreground)/60 font-space uppercase tracking-tighter\" data-kid=\"187\">\n            <li data-kid=\"188\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"189\">Uptime</a></li>\n            <li data-kid=\"190\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"191\">Security</a></li>\n            <li data-kid=\"192\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"193\">API Docs</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"194\">\n          <h5 class=\"font-space text-[10px] uppercase tracking-widest opacity-40 mb-6\" data-kid=\"195\">Legal</h5>\n          <ul class=\"text-sm space-y-4 text-(--foreground)/60 font-space uppercase tracking-tighter\" data-kid=\"196\">\n            <li data-kid=\"197\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"198\">Privacy</a></li>\n            <li data-kid=\"199\"><a href=\"#\" class=\"hover:text-(--primary)\" data-kid=\"200\">Terms</a></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n    <div class=\"max-w-7xl mx-auto mt-20 pt-8 border-t border-(--border) flex justify-between items-center opacity-40 text-[10px] font-space tracking-widest uppercase\" data-kid=\"201\">\n      <span data-kid=\"202\">© 2026 GTRAN CORE</span>\n      <span data-kid=\"203\">WEST AFRICA NODE-01</span>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"204\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"205\"></script>\n<script data-kid=\"206\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Animations\n  gsap.from(\".hero-title\", {\n    duration: 1.2,\n    y: 50,\n    opacity: 0,\n    ease: \"power4.out\",\n    delay: 0.2\n  });\n\n  gsap.from(\".hero-sub\", {\n    duration: 1.2,\n    y: 30,\n    opacity: 0,\n    ease: \"power4.out\",\n    delay: 0.4\n  });\n\n  gsap.from(\".hero-btns\", {\n    duration: 1.2,\n    y: 20,\n    opacity: 0,\n    ease: \"power4.out\",\n    delay: 0.6\n  });\n\n  gsap.from(\".hero-visual\", {\n    duration: 1.5,\n    x: 100,\n    opacity: 0,\n    ease: \"power4.out\",\n    delay: 0.3\n  });\n\n  // Data Glitch effect on scroll\n  const cards = document.querySelectorAll('.bento-card');\n  cards.forEach(card => {\n    gsap.from(card, {\n      scrollTrigger: {\n        trigger: card,\n        start: \"top 90%\",\n      },\n      duration: 0.8,\n      y: 40,\n      opacity: 0,\n      ease: \"expo.out\"\n    });\n  });\n\n  // Timeline progression\n  const timelineLine = document.querySelector(\".absolute.left-1/2.top-0\");\n  if(timelineLine) {\n    gsap.from(timelineLine, {\n      scrollTrigger: {\n        trigger: \".relative.max-w-4xl\",\n        start: \"top center\",\n        end: \"bottom center\",\n        scrub: 1\n      },\n      scaleY: 0,\n      transformOrigin: \"top center\"\n    });\n  }\n</script>",
