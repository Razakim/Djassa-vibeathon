      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  @layer base {\n    body {\n      font-family: 'Inter', sans-serif;\n      overflow-x: hidden;\n      @apply bg-[var(--background)] text-[var(--foreground)];\n    }\n    h1, h2, h3, h4 {\n      font-family: 'Plus Jakarta Sans', sans-serif;\n    }\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n  }\n\n  .gradient-text {\n    background: linear-gradient(135deg, var(--primary) 0%, var(--chart-2) 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .pulse-line {\n    stroke-dasharray: 10;\n    animation: dash 20s linear infinite;\n  }\n\n  @keyframes dash {\n    to {\n      stroke-dashoffset: -1000;\n    }\n  }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-8 py-4 glass-card mx-8 mt-6 rounded-2xl\" data-kid=\"1\">\n  <div class=\"flex items-center gap-2\" data-kid=\"2\">\n    <div class=\"w-8 h-8 bg-[var(--primary)] rounded-lg flex items-center justify-center text-white font-bold\" data-kid=\"3\">G</div>\n    <span class=\"text-xl font-bold tracking-tight font-[Plus_Jakarta_Sans]\" data-kid=\"4\">Gtran</span>\n  </div>\n  <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-[var(--muted-foreground)]\" data-kid=\"5\">\n    <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"6\">Plateforme</a>\n    <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"7\">Modules</a>\n    <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"8\">Écosystème</a>\n    <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"9\">Tarifs</a>\n  </div>\n  <div class=\"flex items-center gap-4\" data-kid=\"10\">\n    <button class=\"text-sm font-semibold px-4 py-2\" data-kid=\"11\">Connexion</button>\n    <button class=\"text-sm font-semibold bg-[var(--primary)] text-[var(--primary-foreground)] px-6 py-2.5 rounded-xl hover:opacity-90 transition-opacity\" data-kid=\"12\">Essai gratuit</button>\n  </div>\n</nav>\n\n\n<section class=\"relative pt-40 pb-20 px-8 overflow-hidden\" data-kid=\"13\">\n  \n  <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-10\" data-kid=\"14\">\n    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/waves.svg\" class=\"w-full h-full object-cover text-[var(--primary)]\" data-kid=\"15\">\n  </div>\n  <div class=\"absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-[var(--chart-2)]/10 blur-[120px] rounded-full -z-10\" data-kid=\"16\"></div>\n  <div class=\"absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-[var(--primary)]/10 blur-[120px] rounded-full -z-10\" data-kid=\"17\"></div>\n\n  <div class=\"max-w-4xl mx-auto text-center\" data-kid=\"18\">\n    <div id=\"hero-badge\" class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--secondary)] border border-[var(--border)] text-xs font-semibold mb-6\" data-kid=\"19\">\n      <span class=\"flex h-2 w-2 rounded-full bg-[var(--chart-2)]\" data-kid=\"20\"></span>\n      L'OS du transport en Afrique de l'Ouest\n    </div>\n    <h1 id=\"hero-title\" class=\"text-6xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-8\" data-kid=\"21\">\n      L'infrastructure numérique du <span class=\"gradient-text\" data-kid=\"22\">transport routier.</span>\n    </h1>\n    <p id=\"hero-desc\" class=\"text-lg text-[var(--muted-foreground)] max-w-2xl mx-auto mb-10 leading-relaxed\" data-kid=\"23\">\n      Centralisez votre flotte, vos chauffeurs et vos missions sur une plateforme unique. Remplacez le chaos des groupes WhatsApp et des fichiers Excel par une efficacité chirurgicale.\n    </p>\n    <div id=\"hero-ctas\" class=\"flex flex-col sm:flex-row items-center justify-center gap-4\" data-kid=\"24\">\n      <button class=\"w-full sm:w-auto px-8 py-4 bg-[var(--primary)] text-[var(--primary-foreground)] rounded-2xl font-bold text-lg shadow-xl shadow-[var(--primary)]/20 hover:-translate-y-1 transition-transform\" data-kid=\"25\">Démarrer maintenant</button>\n      <button class=\"w-full sm:w-auto px-8 py-4 bg-white border border-[var(--border)] rounded-2xl font-bold text-lg flex items-center justify-center gap-2 hover:bg-[var(--secondary)] transition-colors\" data-kid=\"26\">\n        <i class=\"ti ti-player-play-filled text-sm\" data-kid=\"27\"></i> Voir la démo\n      </button>\n    </div>\n  </div>\n\n  \n  <div class=\"mt-20 relative max-w-6xl mx-auto\" data-kid=\"28\">\n    <div id=\"mockup-container\" class=\"relative aspect-[16/9] w-full\" data-kid=\"29\">\n      \n      <div id=\"mockup-desktop\" class=\"absolute inset-0 z-20 translate-y-10\" data-kid=\"30\">\n        <div class=\"w-full h-full bg-white rounded-3xl shadow-2xl border border-[var(--border)] overflow-hidden flex\" data-kid=\"31\">\n          <div class=\"w-64 bg-[var(--secondary)] border-r border-[var(--border)] p-6 space-y-6\" data-kid=\"32\">\n            <div class=\"h-4 w-32 bg-[var(--muted-foreground)]/20 rounded-full\" data-kid=\"33\"></div>\n            <div class=\"space-y-4\" data-kid=\"34\">\n              <div class=\"h-8 w-full bg-[var(--primary)]/10 rounded-lg\" data-kid=\"35\"></div>\n              <div class=\"h-8 w-full bg-transparent rounded-lg\" data-kid=\"36\"></div>\n              <div class=\"h-8 w-full bg-transparent rounded-lg\" data-kid=\"37\"></div>\n            </div>\n          </div>\n          <div class=\"flex-1 p-8 space-y-8\" data-kid=\"38\">\n            <div class=\"flex justify-between\" data-kid=\"39\">\n              <div class=\"h-10 w-48 bg-[var(--muted-foreground)]/10 rounded-xl\" data-kid=\"40\"></div>\n              <div class=\"h-10 w-10 bg-[var(--muted-foreground)]/10 rounded-full\" data-kid=\"41\"></div>\n            </div>\n            <div class=\"grid grid-cols-3 gap-6\" data-kid=\"42\">\n              <div class=\"h-32 bg-[var(--muted)] rounded-2xl p-4 flex flex-col justify-between\" data-kid=\"43\">\n                <span class=\"text-xs font-bold text-[var(--muted-foreground)]\" data-kid=\"44\">FLOTTE ACTIVE</span>\n                <span class=\"text-3xl font-extrabold\" data-kid=\"45\">94%</span>\n              </div>\n              <div class=\"h-32 bg-[var(--muted)] rounded-2xl p-4 flex flex-col justify-between\" data-kid=\"46\">\n                <span class=\"text-xs font-bold text-[var(--muted-foreground)]\" data-kid=\"47\">MISSIONS EN COURS</span>\n                <span class=\"text-3xl font-extrabold text-[var(--chart-2)]\" data-kid=\"48\">128</span>\n              </div>\n              <div class=\"h-32 bg-[var(--muted)] rounded-2xl p-4 flex flex-col justify-between\" data-kid=\"49\">\n                <span class=\"text-xs font-bold text-[var(--muted-foreground)]\" data-kid=\"50\">MARGE RÉELLE</span>\n                <span class=\"text-3xl font-extrabold text-[var(--primary)]\" data-kid=\"51\">+24.5%</span>\n              </div>\n            </div>\n            <div class=\"h-64 bg-[var(--muted)]/50 border border-dashed border-[var(--border)] rounded-3xl flex items-center justify-center\" data-kid=\"52\">\n              <div class=\"text-[var(--muted-foreground)] text-sm italic\" data-kid=\"53\">Visualisation cartographique en temps réel</div>\n            </div>\n          </div>\n        </div>\n      </div>\n      \n      <div id=\"mockup-tablet\" class=\"absolute -left-12 bottom-12 z-30 w-1/3 aspect-[3/4] bg-white rounded-2xl shadow-2xl border border-[var(--border)] overflow-hidden p-4\" data-kid=\"54\">\n        <div class=\"h-4 w-20 bg-[var(--muted-foreground)]/20 rounded-full mb-6\" data-kid=\"55\"></div>\n        <div class=\"space-y-4\" data-kid=\"56\">\n          <div class=\"flex items-center gap-3 p-3 bg-[var(--secondary)] rounded-xl\" data-kid=\"57\">\n             <i class=\"ti ti-truck text-[var(--primary)]\" data-kid=\"58\"></i>\n             <div class=\"flex-1\" data-kid=\"59\">\n               <div class=\"h-2 w-16 bg-[var(--primary)]/40 rounded-full mb-2\" data-kid=\"60\"></div>\n               <div class=\"h-2 w-24 bg-[var(--muted-foreground)]/20 rounded-full\" data-kid=\"61\"></div>\n             </div>\n          </div>\n          <div class=\"flex items-center gap-3 p-3 bg-white border border-[var(--border)] rounded-xl\" data-kid=\"62\">\n             <i class=\"ti ti-truck text-[var(--muted-foreground)]\" data-kid=\"63\"></i>\n             <div class=\"flex-1\" data-kid=\"64\">\n               <div class=\"h-2 w-20 bg-[var(--muted-foreground)]/20 rounded-full mb-2\" data-kid=\"65\"></div>\n               <div class=\"h-2 w-28 bg-[var(--muted-foreground)]/10 rounded-full\" data-kid=\"66\"></div>\n             </div>\n          </div>\n        </div>\n      </div>\n      \n      <div id=\"mockup-mobile\" class=\"absolute -right-8 top-12 z-40 w-1/5 aspect-[9/19] bg-[var(--primary)] rounded-[40px] shadow-2xl border-[6px] border-[var(--foreground)] overflow-hidden p-6 text-white\" data-kid=\"67\">\n        <div class=\"w-12 h-1 bg-white/20 rounded-full mx-auto mb-8\" data-kid=\"68\"></div>\n        <div class=\"text-xs font-medium opacity-60 mb-1\" data-kid=\"69\">MISSION ACTUELLE</div>\n        <div class=\"text-lg font-bold mb-6\" data-kid=\"70\">Abidjan → Bamako</div>\n        <div class=\"space-y-4\" data-kid=\"71\">\n          <div class=\"p-4 bg-white/10 rounded-2xl\" data-kid=\"72\">\n             <div class=\"text-[10px] opacity-60 mb-2\" data-kid=\"73\">ÉTAPE SUIVANTE</div>\n             <div class=\"text-xs font-semibold\" data-kid=\"74\">Chargement en cours</div>\n             <div class=\"mt-4 flex gap-1\" data-kid=\"75\">\n               <div class=\"h-1 flex-1 bg-[var(--chart-2)] rounded-full\" data-kid=\"76\"></div>\n               <div class=\"h-1 flex-1 bg-white/20 rounded-full\" data-kid=\"77\"></div>\n               <div class=\"h-1 flex-1 bg-white/20 rounded-full\" data-kid=\"78\"></div>\n             </div>\n          </div>\n          <button class=\"w-full py-3 bg-[var(--chart-2)] rounded-xl font-bold text-xs\" data-kid=\"79\">Confirmer le chargement</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-8 bg-[var(--secondary)]/30\" data-kid=\"80\">\n  <div class=\"max-w-6xl mx-auto\" data-kid=\"81\">\n    <div class=\"text-center mb-20\" data-kid=\"82\">\n      <h2 class=\"text-4xl font-extrabold mb-4\" data-kid=\"83\">Une journée avec Gtran</h2>\n      <p class=\"text-[var(--muted-foreground)]\" data-kid=\"84\">Voyez comment l'information circule sans friction, de l'aube au crépuscule.</p>\n    </div>\n\n    <div class=\"grid md:grid-cols-2 gap-20 items-start\" data-kid=\"85\">\n      <div class=\"space-y-24 py-10\" data-kid=\"86\">\n        \n        <div class=\"timeline-step flex gap-6 group\" data-kid=\"87\">\n          <div class=\"flex flex-col items-center\" data-kid=\"88\">\n            <div class=\"w-12 h-12 rounded-full bg-white border border-[var(--border)] flex items-center justify-center text-[var(--primary)] font-bold group-hover:bg-[var(--primary)] group-hover:text-white transition-colors\" data-kid=\"89\">\n              <i class=\"ti ti-clock\" data-kid=\"90\"></i>\n            </div>\n            <div class=\"w-px h-full bg-[var(--border)] mt-4\" data-kid=\"91\"></div>\n          </div>\n          <div class=\"pb-10\" data-kid=\"92\">\n            <div class=\"text-sm font-bold text-[var(--primary)] mb-2\" data-kid=\"93\">06:00</div>\n            <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"94\">Assignation intelligente</h3>\n            <p class=\"text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"95\">Le système détecte les chauffeurs disponibles et les véhicules prêts. Une mission est créée et envoyée instantanément sur le mobile du chauffeur.</p>\n          </div>\n        </div>\n        \n        <div class=\"timeline-step flex gap-6 group\" data-kid=\"96\">\n          <div class=\"flex flex-col items-center\" data-kid=\"97\">\n            <div class=\"w-12 h-12 rounded-full bg-white border border-[var(--border)] flex items-center justify-center text-[var(--primary)] font-bold group-hover:bg-[var(--primary)] group-hover:text-white transition-colors\" data-kid=\"98\">\n              <i class=\"ti ti-truck-delivery\" data-kid=\"99\"></i>\n            </div>\n            <div class=\"w-px h-full bg-[var(--border)] mt-4\" data-kid=\"100\"></div>\n          </div>\n          <div class=\"pb-10\" data-kid=\"101\">\n            <div class=\"text-sm font-bold text-[var(--primary)] mb-2\" data-kid=\"102\">10:30</div>\n            <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"103\">Suivi en temps réel</h3>\n            <p class=\"text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"104\">Le chauffeur confirme le départ. La géolocalisation GPS s'active. Le gestionnaire voit la progression sur son tableau de bord sans passer un seul appel.</p>\n          </div>\n        </div>\n        \n        <div class=\"timeline-step flex gap-6 group\" data-kid=\"105\">\n          <div class=\"flex flex-col items-center\" data-kid=\"106\">\n            <div class=\"w-12 h-12 rounded-full bg-white border border-[var(--border)] flex items-center justify-center text-[var(--primary)] font-bold group-hover:bg-[var(--primary)] group-hover:text-white transition-colors\" data-kid=\"107\">\n              <i class=\"ti ti-check-circle\" data-kid=\"108\"></i>\n            </div>\n          </div>\n          <div data-kid=\"109\">\n            <div class=\"text-sm font-bold text-[var(--primary)] mb-2\" data-kid=\"110\">16:45</div>\n            <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"111\">Preuve de livraison digitale</h3>\n            <p class=\"text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"112\">Le client signe directement sur le smartphone du chauffeur. Le document est centralisé, la facture générée automatiquement.</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"sticky top-40 rounded-3xl overflow-hidden shadow-2xl border border-[var(--border)] bg-white aspect-square flex items-center justify-center\" data-kid=\"113\">\n        <img src=\"https://images.unsplash.com/photo-1583234736509-8efd1a126e0d?auto=format&w=800&q=80&fit=crop\" alt=\"Michael Kumordzi Tetteh on Unsplash\" decoding=\"async\" loading=\"lazy\" class=\"w-full h-full object-cover\" data-kid=\"114\">\n        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--primary)]/60 to-transparent\" data-kid=\"115\"></div>\n        <div class=\"absolute bottom-8 left-8 right-8 text-white\" data-kid=\"116\">\n          <div class=\"flex items-center gap-3 mb-2\" data-kid=\"117\">\n            <img src=\"https://i.pravatar.cc/100?u=driver1\" class=\"w-10 h-10 rounded-full border-2 border-white\" data-kid=\"118\">\n            <div data-kid=\"119\">\n              <div class=\"text-sm font-bold\" data-kid=\"120\">Moussa Traoré</div>\n              <div class=\"text-[10px] opacity-80\" data-kid=\"121\">Chauffeur certifié Gtran</div>\n            </div>\n          </div>\n          <div class=\"text-xl font-bold\" data-kid=\"122\">\"Depuis Gtran, je ne perds plus de temps avec les papiers. Tout est clair sur mon téléphone.\"</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-8 overflow-hidden relative\" data-kid=\"123\">\n  <div class=\"max-w-6xl mx-auto text-center\" data-kid=\"124\">\n    <h2 class=\"text-4xl font-extrabold mb-16\" data-kid=\"125\">Un écosystème en expansion</h2>\n    \n    <div class=\"relative w-full max-w-2xl mx-auto aspect-square flex items-center justify-center\" data-kid=\"126\">\n      \n      <svg class=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 400 400\" data-kid=\"127\">\n        <line x1=\"200\" y1=\"200\" x2=\"80\" y2=\"80\" stroke=\"var(--border)\" stroke-width=\"2\" class=\"pulse-line\" data-kid=\"128\"></line>\n        <line x1=\"200\" y1=\"200\" x2=\"320\" y2=\"80\" stroke=\"var(--border)\" stroke-width=\"2\" class=\"pulse-line\" data-kid=\"129\"></line>\n        <line x1=\"200\" y1=\"200\" x2=\"80\" y2=\"320\" stroke=\"var(--border)\" stroke-width=\"2\" class=\"pulse-line\" data-kid=\"130\"></line>\n        <line x1=\"200\" y1=\"200\" x2=\"320\" y2=\"320\" stroke=\"var(--border)\" stroke-width=\"2\" class=\"pulse-line\" data-kid=\"131\"></line>\n      </svg>\n\n      \n      <div class=\"relative z-10 w-32 h-32 rounded-3xl bg-[var(--primary)] shadow-2xl flex items-center justify-center text-white text-5xl font-extrabold\" data-kid=\"132\">\n        G\n      </div>\n\n      \n      <div class=\"absolute top-0 left-0 w-24 h-24 rounded-2xl glass-card flex flex-col items-center justify-center gap-2 -translate-x-1/2 -translate-y-1/2 shadow-xl hover:-translate-y-8 transition-transform duration-500\" data-kid=\"133\">\n        <i class=\"ti ti-building-store text-2xl text-[var(--primary)]\" data-kid=\"134\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"135\">MARKETPLACE</span>\n      </div>\n      <div class=\"absolute top-0 right-0 w-24 h-24 rounded-2xl glass-card flex flex-col items-center justify-center gap-2 translate-x-1/2 -translate-y-1/2 shadow-xl hover:-translate-y-8 transition-transform duration-500\" data-kid=\"136\">\n        <i class=\"ti ti-shield-check text-2xl text-[var(--primary)]\" data-kid=\"137\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"138\">ASSURANCE</span>\n      </div>\n      <div class=\"absolute bottom-0 left-0 w-24 h-24 rounded-2xl glass-card flex flex-col items-center justify-center gap-2 -translate-x-1/2 translate-y-1/2 shadow-xl hover:translate-y-8 transition-transform duration-500\" data-kid=\"139\">\n        <i class=\"ti ti-credit-card text-2xl text-[var(--primary)]\" data-kid=\"140\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"141\">FINANCEMENT</span>\n      </div>\n      <div class=\"absolute bottom-0 right-0 w-24 h-24 rounded-2xl glass-card flex flex-col items-center justify-center gap-2 translate-x-1/2 translate-y-1/2 shadow-xl hover:translate-y-8 transition-transform duration-500\" data-kid=\"142\">\n        <i class=\"ti ti-settings text-2xl text-[var(--primary)]\" data-kid=\"143\"></i>\n        <span class=\"text-[10px] font-bold\" data-kid=\"144\">MAINTENANCE</span>\n      </div>\n    </div>\n    \n    <p class=\"mt-20 text-[var(--muted-foreground)] max-w-2xl mx-auto\" data-kid=\"145\">\n      Gtran n'est pas qu'un logiciel de gestion. C'est le point d'entrée vers tous les services dont votre entreprise a besoin pour croître sereinement.\n    </p>\n  </div>\n</section>\n\n\n<section class=\"pb-20 px-8\" data-kid=\"146\">\n  \n  <div class=\"max-w-6xl mx-auto bg-[var(--primary)] rounded-[32px] p-12 md:p-20 text-center text-white relative overflow-hidden mb-32 shadow-2xl shadow-[var(--primary)]/30\" data-kid=\"147\">\n    <div class=\"absolute top-0 left-0 w-full h-full opacity-10\" data-kid=\"148\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/waves.svg\" class=\"w-full h-full object-cover text-white\" data-kid=\"149\">\n    </div>\n    <div class=\"relative z-10\" data-kid=\"150\">\n      <h2 class=\"text-4xl md:text-5xl font-extrabold mb-6\" data-kid=\"151\">Prêt à transformer votre logistique ?</h2>\n      <p class=\"text-xl opacity-80 mb-10 max-w-xl mx-auto\" data-kid=\"152\">Rejoignez les entreprises qui pilotent déjà l'avenir du transport en Afrique de l'Ouest.</p>\n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\" data-kid=\"153\">\n        <button class=\"w-full sm:w-auto px-10 py-5 bg-[var(--chart-2)] text-[var(--primary)] rounded-2xl font-bold text-lg hover:scale-105 transition-transform\" data-kid=\"154\">Démarrer l'essai gratuit</button>\n        <button class=\"w-full sm:w-auto px-10 py-5 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl font-bold text-lg hover:bg-white/20 transition-colors\" data-kid=\"155\">Contacter un expert</button>\n      </div>\n    </div>\n  </div>\n\n  <footer class=\"max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-12 border-t border-[var(--border)] pt-20\" data-kid=\"156\">\n    <div class=\"col-span-2 md:col-span-1\" data-kid=\"157\">\n      <div class=\"flex items-center gap-2 mb-6\" data-kid=\"158\">\n        <div class=\"w-8 h-8 bg-[var(--primary)] rounded-lg flex items-center justify-center text-white font-bold\" data-kid=\"159\">G</div>\n        <span class=\"text-xl font-bold tracking-tight font-[Plus_Jakarta_Sans]\" data-kid=\"160\">Gtran</span>\n      </div>\n      <p class=\"text-sm text-[var(--muted-foreground)] leading-relaxed\" data-kid=\"161\">\n        L'infrastructure numérique du transport routier pour une Afrique connectée et prospère.\n      </p>\n    </div>\n    <div data-kid=\"162\">\n      <h4 class=\"font-bold mb-6\" data-kid=\"163\">Plateforme</h4>\n      <ul class=\"space-y-4 text-sm text-[var(--muted-foreground)]\" data-kid=\"164\">\n        <li data-kid=\"165\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"166\">Flotte</a></li>\n        <li data-kid=\"167\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"168\">Chauffeurs</a></li>\n        <li data-kid=\"169\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"170\">Missions</a></li>\n        <li data-kid=\"171\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"172\">Suivi GPS</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"173\">\n      <h4 class=\"font-bold mb-6\" data-kid=\"174\">Entreprise</h4>\n      <ul class=\"space-y-4 text-sm text-[var(--muted-foreground)]\" data-kid=\"175\">\n        <li data-kid=\"176\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"177\">À propos</a></li>\n        <li data-kid=\"178\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"179\">Carrières</a></li>\n        <li data-kid=\"180\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"181\">Partenaires</a></li>\n        <li data-kid=\"182\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"183\">Contact</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"184\">\n      <h4 class=\"font-bold mb-6\" data-kid=\"185\">Légal</h4>\n      <ul class=\"space-y-4 text-sm text-[var(--muted-foreground)]\" data-kid=\"186\">\n        <li data-kid=\"187\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"188\">Confidentialité</a></li>\n        <li data-kid=\"189\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"190\">CGU</a></li>\n        <li data-kid=\"191\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"192\">Cookies</a></li>\n      </ul>\n    </div>\n  </footer>\n  <div class=\"max-w-6xl mx-auto mt-20 text-center text-[var(--muted-foreground)] text-xs\" data-kid=\"193\">\n    © 2026 Gtran Logistics OS. Tous droits réservés.\n  </div>\n</section>\n\n<script type=\"module\" data-kid=\"194\">\n  import { animate, scroll, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Hero Animations\n  animate(\"#hero-badge\", { opacity: [0, 1], y: [20, 0] }, { duration: 0.8, delay: 0.2 });\n  animate(\"#hero-title\", { opacity: [0, 1], y: [20, 0] }, { duration: 0.8, delay: 0.4 });\n  animate(\"#hero-desc\", { opacity: [0, 1], y: [20, 0] }, { duration: 0.8, delay: 0.6 });\n  animate(\"#hero-ctas\", { opacity: [0, 1], y: [20, 0] }, { duration: 0.8, delay: 0.8 });\n\n  // Floating Mockups\n  animate(\"#mockup-desktop\", { opacity: [0, 1], y: [60, 0] }, { duration: 1.2, delay: 1 });\n  animate(\"#mockup-tablet\", { x: [-100, 0], opacity: [0, 1] }, { duration: 1.2, delay: 1.2 });\n  animate(\"#mockup-mobile\", { x: [100, 0], opacity: [0, 1] }, { duration: 1.2, delay: 1.4 });\n\n  // Scroll animations for timeline\n  inView(\".timeline-step\", (info) => {\n    animate(info.target, { opacity: [0, 1], x: [-50, 0] }, { duration: 0.8 });\n  });\n\n  // Pulse effect for connection lines\n  animate(\".pulse-line\", { opacity: [0.3, 1] }, { duration: 2, repeat: Infinity, direction: \"alternate\" });\n</script>",
